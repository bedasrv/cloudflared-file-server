#!/usr/bin/env bash
# cloudflared-serve — non-blocking Cloudflare Quick Tunnel file server
# Spins up caddy:alpine, downloads cloudflared, serves files, self-destructs.
# Usage: cloudflared-serve <ttl> <file1> [file2 ...]
# TTL format: 30s, 5m, 1h (minimum 10s)

# To pin cloudflared to a specific version:
#   CLOUDFLARED_VERSION=2025.2.1 cloudflared-serve 5m file.txt
# Default: 'latest' (GitHub redirects to newest release).
CLOUDFLARED_VERSION="${CLOUDFLARED_VERSION:-latest}"
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: cloudflared-serve <ttl> <file1> [file2 ...]

Serve files via temporary Cloudflare Quick Tunnel. Script returns immediately with
the tunnel URL. Container self-destructs after TTL.

Arguments:
  ttl      Auto-shutdown timer: 30s, 5m, 1h (minimum 10s)
  file(s)  Files or directories to serve

Examples:
  cloudflared-serve 5m cat.png dog.png parrot.png
  cloudflared-serve 30s image.png
  cloudflared-serve 1h ./downloads/
EOF
    exit 1
}

# --- Parse TTL (first argument) ---
TTL="${1:-}"
# shift may fail if called with 0 args (caught by [ -z "$TTL" ] above); || true
# prevents set -e from aborting on the edge case where usage() has already run.
shift 2>/dev/null || true

[ -z "$TTL" ] && usage

case "$TTL" in
    *s) SECS="${TTL%s}" ;;
    *m) SECS=$((${TTL%m} * 60)) ;;
    *h) SECS=$((${TTL%h} * 3600)) ;;
    *)  echo "ERROR: Invalid TTL: $TTL (use 30s, 5m, 1h)" >&2; exit 1 ;;
esac

# Reject non-numeric (e.g. 'abcm', 'm' → arithmetic produces 0 or empty)
[[ "$SECS" =~ ^[0-9]+$ ]] || { echo "ERROR: Invalid TTL: $TTL" >&2; exit 1; }

# Enforce minimum TTL — 0s/0m/0h kills container before URL is served
if [ "$SECS" -lt 10 ]; then
    echo "ERROR: TTL too short (minimum 10s, got ${SECS}s)" >&2
    exit 1
fi

# --- Parse files ---
FILES=("$@")
if [ ${#FILES[@]} -eq 0 ]; then
    usage
fi

# Validate
for f in "${FILES[@]}"; do
    if [ ! -e "$f" ]; then
        echo "ERROR: '$f' not found" >&2
        exit 1
    fi
done

# --- Container and serve dir names ---
CONTAINER_NAME="cf-serve-$$"
SERVE_DIR="/tmp/cloudflare-serve-$$"
ENTRYPOINT="/tmp/cf-serve-entrypoint-$$.sh"

# Trap: clean up on error exit (only if container is NOT running).
# Happy-path deferred cleanup is handled by the background docker wait below.
cleanup_on_error() {
    if ! docker inspect "$CONTAINER_NAME" --format '{{.State.Running}}' 2>/dev/null | grep -q true; then
        docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
        [ -d "$SERVE_DIR" ] && rm -rf "$SERVE_DIR"
    fi
    rm -f "$ENTRYPOINT"
}
trap cleanup_on_error EXIT

# --- Cleanup old stale serve dirs from crashed runs ---
find /tmp -maxdepth 1 -name 'cloudflare-serve-*' -type d -mmin +30 -exec rm -rf {} + 2>/dev/null || true

# --- Prepare serve directory (hard links = zero disk overhead) ---
mkdir -p "$SERVE_DIR"
for f in "${FILES[@]}"; do
    name=$(basename "$f")
    if [ -d "$f" ]; then
        if cp -rl "$f" "$SERVE_DIR/$name" 2>/dev/null; then
            : # hard links succeeded
        else
            echo "WARNING: hard links failed for '$f' (cross-device?), falling back to copy" >&2
            cp -r "$f" "$SERVE_DIR/$name"
        fi
    else
        if ln "$f" "$SERVE_DIR/$name" 2>/dev/null; then
            : # hard link succeeded
        else
            echo "WARNING: hard link failed for '$f' (cross-device?), falling back to copy" >&2
            cp "$f" "$SERVE_DIR/$name"
        fi
    fi
done

# --- Cleanup old container (stale from crashed run with same PID) ---
docker rm -f "$CONTAINER_NAME" 2>/dev/null || true

# --- Write entrypoint script (avoids & in docker run command) ---
cat > "$ENTRYPOINT" <<'ENTRYEOF'
#!/bin/sh
set -e

# Trap SIGTERM for graceful shutdown (docker stop forwards it)
cleanup() {
    kill %1 %2 2>/dev/null || true   # caddy, cloudflared
    wait 2>/dev/null || true
}
trap cleanup TERM INT

# Install curl (or fall back to wget) for cloudflared download
if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    apk add --no-cache curl >/dev/null 2>&1 || apk add --no-cache wget >/dev/null 2>&1 || {
        echo "ERROR: failed to install curl or wget" >&2
        exit 1
    }
fi

# Detect architecture for cloudflared download
ARCH=$(uname -m)
case "$ARCH" in
  x86_64)  CF_ARCH="amd64" ;;
  aarch64) CF_ARCH="arm64" ;;
  armv7l)  CF_ARCH="arm" ;;
  *)       echo "ERROR: unsupported architecture: $ARCH" >&2; exit 1 ;;
esac

# Download cloudflared (version pinning via CLOUDFLARED_VERSION env var)
CLOUDFLARED_VERSION="${CLOUDFLARED_VERSION:-latest}"
if [ "$CLOUDFLARED_VERSION" = "latest" ]; then
    CLOUDFLARED_URL="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${CF_ARCH}"
else
    CLOUDFLARED_URL="https://github.com/cloudflare/cloudflared/releases/download/${CLOUDFLARED_VERSION}/cloudflared-linux-${CF_ARCH}"
fi

if command -v curl >/dev/null 2>&1; then
    curl -fsSL --connect-timeout 10 --max-time 300 "$CLOUDFLARED_URL" -o /usr/local/bin/cloudflared
else
    wget -q --timeout=10 --tries=3 "$CLOUDFLARED_URL" -O /usr/local/bin/cloudflared
fi
chmod +x /usr/local/bin/cloudflared

cd /serve
caddy file-server --listen :80 &
CADDY_PID=$!
sleep 1
cloudflared tunnel --url http://localhost:80 &
CF_PID=$!
# Timer starts AFTER both processes are running.
# SECS is set by the host script and passed as an env var (always in seconds).
(sleep "$SECS"; kill $CF_PID 2>/dev/null) &
wait $CF_PID
ENTRYEOF
chmod +x "$ENTRYPOINT"

# --- Start container (detached) ---
docker run -d --name "$CONTAINER_NAME" \
    -v "$SERVE_DIR:/serve:ro" \
    -v "$ENTRYPOINT:/entrypoint.sh:ro" \
    -e SECS="$SECS" \
    -e CLOUDFLARED_VERSION="$CLOUDFLARED_VERSION" \
    --entrypoint sh \
    caddy:alpine /entrypoint.sh
DOCKER_EXIT=$?

# Remove temp entrypoint immediately (mounted, inode stays until container exits)
rm -f "$ENTRYPOINT"

if [ "$DOCKER_EXIT" -ne 0 ]; then
    echo "ERROR: docker run failed (exit code $DOCKER_EXIT)" >&2
    exit 1
fi

# Verify container actually started. Retry up to 3 times with 0.5s delay —
# docker run -d returns before the container reaches Running state on slow hosts.
STARTED=false
for attempt in 1 2 3; do
    if docker inspect "$CONTAINER_NAME" --format '{{.State.Running}}' 2>/dev/null | grep -q true; then
        STARTED=true
        break
    fi
    [ "$attempt" -lt 3 ] && sleep 0.5
done
if [ "$STARTED" = false ]; then
    echo "ERROR: Container failed to start. Check docker logs." >&2
    docker logs "$CONTAINER_NAME" 2>&1 | tail -20 >&2
    exit 1
fi

# --- Poll for tunnel URL ---
URL=""
for i in $(seq 1 120); do
    sleep 1
    # Check if container still exists
    docker inspect "$CONTAINER_NAME" --format '{{.State.Running}}' 2>/dev/null | grep -q true || {
        echo "ERROR: Container died before tunnel came up" >&2
        docker logs "$CONTAINER_NAME" 2>&1 | tail -20 >&2
        docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
        exit 1
    }
    # POSIX grep (no -P PCRE — not available on macOS/Alpine).
    # Pattern handles single-label subdomains (abc-123.trycloudflare.com) and
    # future multi-level subdomains (a.b.trycloudflare.com) if Cloudflare changes format.
    URL=$(docker logs "$CONTAINER_NAME" 2>&1 | grep -o 'https://[a-z0-9.-]*\.trycloudflare\.com' | head -1 || true)
    [ -n "$URL" ] && break
done

if [ -z "$URL" ]; then
    echo "ERROR: Failed to get tunnel URL (check: docker logs $CONTAINER_NAME)" >&2
    docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
    exit 1
fi

# --- Print URL and exit ---
echo "$URL"

# Info output to stderr (keeps stdout clean: just the URL)
{
    echo ""
    echo "[INFO] Serving ${#FILES[@]} file(s) — expires in ${TTL}:"
    for f in "${FILES[@]}"; do
        name=$(basename "$f")
        echo "[INFO]   $URL/$name"
    done
    echo ""
    echo "[INFO] Auto-shutdown in ${TTL} (${SECS}s). Manual kill: docker rm -f $CONTAINER_NAME"

    # Background cleanup: wait for container to exit, then remove serve dir.
    # Timeout scales with TTL + 120s buffer (minimum 60s) to avoid zombie processes.
    WAIT_TIMEOUT=$((SECS + 120))
    [ "$WAIT_TIMEOUT" -lt 60 ] && WAIT_TIMEOUT=60
    (timeout "$WAIT_TIMEOUT" docker wait "$CONTAINER_NAME" >/dev/null 2>&1; rm -rf "$SERVE_DIR") &
} >&2
