#!/usr/bin/env bash
# cloudflared-serve — non-blocking Cloudflare Quick Tunnel file server
# Spins up caddy:alpine, serves files, self-destructs after TTL.
# Usage: cloudflared-serve <ttl> <file1> [file2 ...]
# TTL format: 30s, 5m, 1h (minimum 10s)
#
# Cloudflared binary is cached on host at /tmp/cloudflared-cache/ for 24h.
# Set CLOUDFLARED_VERSION to pin a specific release (default: latest).

CLOUDFLARED_VERSION="${CLOUDFLARED_VERSION:-latest}"
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: cloudflared-serve <ttl> <file1> [file2 ...]

Serve files via temporary Cloudflare Quick Tunnel. One tunnel serves all files.
Script returns immediately with the URL, container self-destructs after TTL.

Arguments:
  ttl      Auto-shutdown timer: 30s, 5m, 1h (minimum 10s)
  file(s)  Files or directories to serve

Examples:
  cloudflared-serve 5m cat.png dog.png parrot.png
  cloudflared-serve 30s image.png
  cloudflared-serve 1h ./downloads/
EOF
    exit 1
}

# --- Parse TTL ---
TTL="${1:-}"
shift 2>/dev/null || true
[ -z "$TTL" ] && usage

case "$TTL" in
    *s) SECS="${TTL%s}" ;;
    *m) SECS=$((${TTL%m} * 60)) ;;
    *h) SECS=$((${TTL%h} * 3600)) ;;
    *)  echo "ERROR: Invalid TTL: $TTL (use 30s, 5m, 1h)" >&2; exit 1 ;;
esac
[[ "$SECS" =~ ^[0-9]+$ ]] || { echo "ERROR: Invalid TTL: $TTL" >&2; exit 1; }
[ "$SECS" -lt 10 ] && { echo "ERROR: TTL too short (minimum 10s, got ${SECS}s)" >&2; exit 1; }

# --- Parse files ---
FILES=("$@")
[ ${#FILES[@]} -eq 0 ] && usage
for f in "${FILES[@]}"; do
    [ -e "$f" ] || { echo "ERROR: '$f' not found" >&2; exit 1; }
done

# --- Names ---
CONTAINER_NAME="cf-serve-$$"
SERVE_DIR="/tmp/cloudflare-serve-$$"
ENTRYPOINT="/tmp/cf-serve-entrypoint-$$.sh"

# --- Trap ---
cleanup_on_error() {
    if ! docker inspect "$CONTAINER_NAME" --format '{{.State.Running}}' 2>/dev/null | grep -q true; then
        docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
        [ -d "$SERVE_DIR" ] && rm -rf "$SERVE_DIR"
    fi
    rm -f "$ENTRYPOINT"
}
trap cleanup_on_error EXIT

# --- Cleanup stale serve dirs from crashed runs ---
find /tmp -maxdepth 1 -name 'cloudflare-serve-*' -type d -mmin +30 -exec rm -rf {} + 2>/dev/null || true

# --- Cloudflared cache (host-side, shared across containers, 24h TTL) ---
CLOUDFLARED_CACHE_DIR="/tmp/cloudflared-cache"
CLOUDFLARED_CACHE_KEY="${CLOUDFLARED_VERSION}-$(uname -m)"
CLOUDFLARED_CACHED="${CLOUDFLARED_CACHE_DIR}/cloudflared-${CLOUDFLARED_CACHE_KEY}"
find "$CLOUDFLARED_CACHE_DIR" -name 'cloudflared-*' -mtime +1 -delete 2>/dev/null || true

if [ ! -x "$CLOUDFLARED_CACHED" ]; then
    echo "[INFO] Downloading cloudflared (${CLOUDFLARED_VERSION}, $(uname -m)) — cached 24h" >&2
    mkdir -p "$CLOUDFLARED_CACHE_DIR"
    case "$(uname -m)" in
        x86_64)  CF_ARCH="amd64" ;;
        aarch64) CF_ARCH="arm64" ;;
        armv7l)  CF_ARCH="arm" ;;
        *)       echo "ERROR: unsupported arch: $(uname -m)" >&2; exit 1 ;;
    esac
    if [ "$CLOUDFLARED_VERSION" = "latest" ]; then
        URL="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${CF_ARCH}"
    else
        URL="https://github.com/cloudflare/cloudflared/releases/download/${CLOUDFLARED_VERSION}/cloudflared-linux-${CF_ARCH}"
    fi
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL --connect-timeout 10 --max-time 300 "$URL" -o "$CLOUDFLARED_CACHED"
    elif command -v wget >/dev/null 2>&1; then
        wget -q --timeout=10 --tries=3 "$URL" -O "$CLOUDFLARED_CACHED"
    else
        echo "ERROR: curl or wget required" >&2; exit 1
    fi
    chmod +x "$CLOUDFLARED_CACHED"
fi

# --- Prepare serve directory (hard links = zero disk overhead) ---
mkdir -p "$SERVE_DIR"
for f in "${FILES[@]}"; do
    name=$(basename "$f")
    if [ -d "$f" ]; then
        if cp -rl "$f" "$SERVE_DIR/$name" 2>/dev/null; then :; else
            echo "WARNING: hard links failed for '$f' (cross-device?), falling back to copy" >&2
            cp -r "$f" "$SERVE_DIR/$name"
        fi
    else
        if ln "$f" "$SERVE_DIR/$name" 2>/dev/null; then :; else
            echo "WARNING: hard link failed for '$f' (cross-device?), falling back to copy" >&2
            cp "$f" "$SERVE_DIR/$name"
        fi
    fi
done

# --- Remove stale container ---
docker rm -f "$CONTAINER_NAME" 2>/dev/null || true

# --- Write entrypoint ---
cat > "$ENTRYPOINT" <<'ENTRYEOF'
#!/bin/sh
set -e
cleanup() { kill %1 %2 2>/dev/null || true; wait 2>/dev/null || true; }
trap cleanup TERM INT
cd /serve
caddy file-server --listen :80 &
sleep 1
cloudflared tunnel --url http://localhost:80 &
CF_PID=$!
(sleep "$SECS"; kill $CF_PID 2>/dev/null) &
wait $CF_PID
ENTRYEOF
chmod +x "$ENTRYPOINT"

# --- Start container ---
docker run -d --name "$CONTAINER_NAME" \
    -v "$SERVE_DIR:/serve:ro" \
    -v "$ENTRYPOINT:/entrypoint.sh:ro" \
    -v "$CLOUDFLARED_CACHED:/usr/local/bin/cloudflared:ro" \
    -e SECS="$SECS" \
    --entrypoint sh \
    caddy:alpine /entrypoint.sh >/dev/null
rm -f "$ENTRYPOINT"

# Verify started
for attempt in 1 2 3; do
    docker inspect "$CONTAINER_NAME" --format '{{.State.Running}}' 2>/dev/null | grep -q true && break
    [ "$attempt" -lt 3 ] && sleep 0.5
done
if ! docker inspect "$CONTAINER_NAME" --format '{{.State.Running}}' 2>/dev/null | grep -q true; then
    echo "ERROR: Container failed to start" >&2
    docker logs "$CONTAINER_NAME" 2>&1 | tail -20 >&2
    exit 1
fi

# --- Poll for URL ---
URL=""
for i in $(seq 1 120); do
    sleep 1
    docker inspect "$CONTAINER_NAME" --format '{{.State.Running}}' 2>/dev/null | grep -q true || {
        echo "ERROR: Container died before tunnel came up" >&2
        docker logs "$CONTAINER_NAME" 2>&1 | tail -20 >&2
        docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
        exit 1
    }
    URL=$(docker logs "$CONTAINER_NAME" 2>&1 | grep -o 'https://[a-z0-9.-]*\.trycloudflare\.com' | head -1 || true)
    [ -n "$URL" ] && break
done

[ -z "$URL" ] && { echo "ERROR: Failed to get tunnel URL" >&2; docker rm -f "$CONTAINER_NAME" 2>/dev/null || true; exit 1; }

# --- Output ---
# stdout: one URL per file, first line = base tunnel URL
echo "$URL"
for f in "${FILES[@]}"; do
    echo "$URL/$(basename "$f")"
done
{
    echo ""
    echo "[INFO] ${#FILES[@]} file(s) — expires in ${TTL} (${SECS}s)"
    echo "[INFO] Kill: docker rm -f $CONTAINER_NAME"
} >&2

# Background cleanup
WAIT_TIMEOUT=$((SECS + 120))
[ "$WAIT_TIMEOUT" -lt 60 ] && WAIT_TIMEOUT=60
(timeout "$WAIT_TIMEOUT" docker wait "$CONTAINER_NAME" >/dev/null 2>&1; rm -rf "$SERVE_DIR") &
